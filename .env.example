# BookAIO – Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs.
# ⚠️  Ne commitez JAMAIS le fichier .env.local dans Git.

# ── Supabase (public – safe to expose in frontend) ──────────────────────────
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_supabase

# ── Maketou (Payment - safe to expose shop URL, keep API key secure) ──────────
VITE_MAKETOU_SHOP_URL=https://maketou.com/s/votre-boutique
VITE_MAKETOU_API_KEY=votre_cle_api_maketou

# ── Cloudinary (public – safe to expose in frontend) ────────────────────────
VITE_CLOUDINARY_URL=https://api.cloudinary.com/v1_1/VOTRE_CLOUD_NAME/image/upload
VITE_CLOUDINARY_UPLOAD_PRESET=votre_upload_preset

# ── Secrets (NE JAMAIS mettre ici – configurer dans Supabase Edge Functions) ─
# Les variables suivantes doivent être configurées via :
#   supabase secrets set N8N_BASE_WEBHOOK_URL=https://...
#   supabase secrets set N8N_WEBHOOK_SECRET=votre_secret
#   supabase secrets set ALLOWED_ORIGIN=https://votre-domaine.com
#
# N8N_BASE_WEBHOOK_URL=  ← NE PAS METTRE ICI
# N8N_WEBHOOK_SECRET=    ← NE PAS METTRE ICI
